anite Model ID (Lite-compatible)
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# ============================================================
#  Flask Application Settings
# ============================================================
# ============================================================
#  IBM watsonx.ai Credentials
#  Copy this file to .env and fill in your actual values.
# ============================================================

# IBM Cloud API Key — obtain from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_api_key_here

# watsonx.ai Project ID — found in your watsonx.ai project settings
WATSONX_PROJECT_ID=your_project_id_here

# watsonx.ai API URL — default Dallas region
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Gr
# Secret key for Flask sessions — change this to a strong random string
SECRET_KEY=change_me_to_a_long_random_secret_key_in_production

# Flask environment: development | production
FLASK_ENV=development

# Port to run the application on
PORT=5000
